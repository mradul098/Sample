{
  "info": {
    "name": "Microservices Tutorial",
    "description": "Postman requests to test the APIGateway, CompanyMicro, and JobMicro project endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. CompanyMicro (Port 8081)",
      "item": [
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Google\",\n  \"description\": \"A technology company\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/companies",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "companies"
              ]
            }
          }
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/companies/{{companyId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "companies",
                "{{companyId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/companies/{{companyId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "companies",
                "{{companyId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. JobMicro (Port 8080)",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Java Developer\",\n  \"description\": \"Backend microservices engineer\",\n  \"companyId\": \"{{companyId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/jobs",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "jobs"
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/jobs/{{jobId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "jobs",
                "{{jobId}}"
              ]
            }
          }
        },
        {
          "name": "Get Jobs by Company ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/jobs/company/{{companyId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "jobs",
                "company",
                "{{companyId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/jobs/delete/{{jobId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "jobs",
                "delete",
                "{{jobId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. APIGateway (Port 8082)",
      "item": [
        {
          "name": "Get Aggregated Company with Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8082/company/{{companyId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "company",
                "{{companyId}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
